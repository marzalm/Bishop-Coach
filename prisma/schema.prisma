// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                  String   @id @default(cuid())
  chesscomUsername    String?
  lichessUsername     String?
  currentTimeControl  String   @default("blitz") // "bullet" | "blitz" | "rapid"
  games               Game[]
  weaknessProfiles    WeaknessProfile[]
  trainingSessions    TrainingSession[]
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model Game {
  id                  String   @id @default(cuid())
  userId              String
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  source              String   // "chesscom" | "lichess"
  pgn                 String
  playedAt            DateTime
  result              String   // "win" | "loss" | "draw"
  color               String   // "white" | "black"
  analyzed            Boolean  @default(false)
  elo                 Int?     // ELO at time of game
  timeControl         String   // "bullet" | "blitz" | "rapid"
  opponent            String?  // opponent username
  errors              GameError[]
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([userId])
  @@index([timeControl])
}

model GameError {
  id                  String  @id @default(cuid())
  gameId              String
  game                Game    @relation(fields: [gameId], references: [id], onDelete: Cascade)
  fen                 String  // position exacte de l'erreur
  movePlayed          String  // coup joué (mauvais)
  bestMove            String  // meilleur coup selon Stockfish
  evalBefore          Float   // évaluation avant le coup
  evalAfter           Float   // évaluation après le coup
  lossInCentipawns    Int     // perte en centipawns
  errorType           String  // "blunder" | "mistake" | "inaccuracy"
  category            String? // "tactic" | "endgame" | "opening" | "positional" | "kingsafety"
  explanation         String? // explication Claude
  trained             Boolean @default(false)
  trainingScore       Int     @default(0) // score de maîtrise (0-100)
  lastTrainedAt       DateTime?
  trainingCount       Int     @default(0)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([gameId])
}

model WeaknessProfile {
  id                  String   @id @default(cuid())
  userId              String
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  timeControl         String   // "bullet" | "blitz" | "rapid"
  weaknesses          String   // JSON array of weaknesses with scores
  topWeaknesses       String   // JSON array of top 3
  gameCount           Int      @default(0)
  analyzedAt          DateTime @updatedAt
  createdAt           DateTime @default(now())

  @@unique([userId, timeControl])
  @@index([userId])
}

model TrainingSession {
  id                  String   @id @default(cuid())
  userId              String
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  errorId             String
  timeControl         String   // "bullet" | "blitz" | "rapid"
  completed           Boolean  @default(false)
  attemptsCount       Int     @default(0)
  hiddenHints         Int     @default(0)
  correctAnswer       Boolean @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([userId])
  @@index([timeControl])
}
